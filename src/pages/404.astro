---
import TerminalLayout from "../layouts/TerminalLayout.astro";
---

<TerminalLayout title="404 — not found" description="This path could not be resolved.">
  <main class="page-wrap" style="min-height:60vh">
    <p class="sec-label" data-reveal><span>// error</span> · 404</p>
    <h1 class="page-title" data-reveal style="font-size:clamp(3rem,12vw,7rem)">404</h1>
    <div class="posts-empty" data-reveal style="margin-top:1rem">
      <p style="margin:0 0 0.4rem"><span class="ok">$</span> cat {Astro.url.pathname}</p>
      <p style="margin:0"><span style="color:var(--amber)">no such file or directory</span> — this path could not be resolved.</p>
    </div>
    <div class="contact-block" data-reveal style="margin-top:2rem">
      <a class="contact-link" href="/"><span class="cl-key">home</span><span class="cl-arrow">→</span> back to the shell</a>
      <a class="contact-link" href="/posts"><span class="cl-key">posts</span><span class="cl-arrow">→</span> read the blog</a>
    </div>
  </main>
</TerminalLayout>
