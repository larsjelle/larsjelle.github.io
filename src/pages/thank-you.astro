---
import TerminalLayout from "../layouts/TerminalLayout.astro";
---

<TerminalLayout title="Thank you — Lars van Blitterswijk" description="Thanks for the support.">
  <main class="page-wrap" style="min-height:60vh">
    <p class="sec-label" data-reveal><span>// thanks</span></p>
    <h1 class="page-title" data-reveal>Thank you ☕</h1>
    <div class="posts-empty" data-reveal style="margin-top:1rem">
      <p style="margin:0 0 0.4rem"><span class="ok">$</span> echo "much appreciated"</p>
      <p style="margin:0">Your support helps keep the lights on and the projects going. Thank you.</p>
    </div>
    <div class="contact-block" data-reveal style="margin-top:2rem">
      <a class="contact-link" href="/"><span class="cl-key">home</span><span class="cl-arrow">→</span> back to the shell</a>
    </div>
  </main>
</TerminalLayout>
